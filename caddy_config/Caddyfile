{
    admin off            # Disable the admin API (avoids TCP 99)
    email you@example.com # Optional: for Let's Encrypt if you use a domain
}

# Main Laravel Octane site
:6080 {
    root * /home/jervi/projects/course-hoster-laravel/public

    encode zstd br gzip   # compression
    php_fastcgi unix//run/php/php8.2-fpm.sock  # adjust PHP-FPM socket if needed

    file_server
    log {
        output file /var/log/caddy/laravel-access.log
        level INFO
    }

    # Allow large uploads (5GB)
    request_body {
        max_size 5GB
    }
}

# Reverb WebSocket
:6081 {
    root * /home/jervi/projects/course-hoster-laravel/public
    encode zstd br gzip
    php_fastcgi unix//run/php/php8.2-fpm.sock

    header_up X-Forwarded-For {remote}
    header_up X-Forwarded-Port {server_port}
    header_up X-Forwarded-Proto {scheme}

    # Optional: WebSocket support (usually automatic via PHP + Octane)
    @ws {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @ws localhost:6081
}